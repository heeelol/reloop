# Frontend env — these are PUBLIC (shipped in the browser bundle). Safe to expose.
# Copy to .env.local and fill in from your Supabase project settings.
VITE_SUPABASE_URL=https://obawenuortkgehznrkre.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key
VITE_ANALYZE_URL=https://obawenuortkgehznrkre.supabase.co/functions/v1/analyze

# NOTE: the OpenAI key is NOT here. It lives ONLY as a Supabase edge-function
# secret (server-side), set via:  npx supabase secrets set OPENAI_API_KEY=sk-...
